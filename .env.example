# SITI INTELLIGENCE — Environment Variables (TEMPLATE)
# ── MongoDB ─────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
DB_NAME=siti_sovereign
# Use the format: mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_ATLAS_URI=your_mongodb_atlas_uri_here

# ── API Security ────────────────────────────────────
# Format: KEY:ROLE,KEY:ROLE
API_KEYS=placeholder_key_admin:ADMIN,placeholder_key_ops:OPERATOR

# ── Razorpay Payments ───────────────────────────────
RAZORPAY_KEY_ID=your_rzp_key_id
RAZORPAY_KEY_SECRET=your_rzp_key_secret
RAZORPAY_WEBHOOK_SECRET=your_rzp_webhook_secret

# ── SendGrid Email ──────────────────────────────────
SENDGRID_KEY=your_sendgrid_api_key

# ── Twilio WhatsApp ─────────────────────────────────
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=your_emergency_contact_number
ALERT_COOLDOWN_MIN=30

# ── CORS ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://your-production-app.vercel.app

# ── System Configuration ────────────────────────────
NODE_ENV=development # Options: development, production, test
LOG_LEVEL=info
DEBUG=false
