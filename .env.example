# ═══════════════════════════════════════════════════════════════
# SITI INTELLIGENCE — Environment Variables
# Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB (required) ─────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
DB_NAME=siti_sovereign

# ── API Security (required) ────────────────────────────────────
API_KEYS=siti-admin-key-001:ADMIN,siti-ops-key-002:OPERATOR,siti-erp-key-003:INTEGRATOR

# ── Razorpay Payments ──────────────────────────────────────────
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PILOT_PLAN_ID=
RAZORPAY_OPERATOR_PLAN_ID=

# ── SendGrid Email ─────────────────────────────────────────────
SENDGRID_KEY=

# ── Twilio WhatsApp ────────────────────────────────────────────
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=
ALERT_COOLDOWN_MIN=30

# ── CORS ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://siti-gsc-kernel.vercel.app
