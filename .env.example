# ═══════════════════════════════════════════════════════════════
# SITI INTELLIGENCE — Environment Variables
# Copy this file to .env and fill in your values.
# This file must be in the root SITI_SOVEREIGN/ folder.
# ═══════════════════════════════════════════════════════════════

# ── MongoDB (required) ─────────────────────────────────────────
# Docker: use container name 'mongo' as host (not localhost!)
MONGO_URL=mongodb://mongo:27017
DB_NAME=siti_sovereign

# ── API Security (required) ────────────────────────────────────
# Format: key:ROLE — comma-separated, no spaces
# Roles: ADMIN, OPERATOR, INTEGRATOR, READONLY
# Generate a key: python3 -c "import secrets; print(secrets.token_hex(20))"
API_KEYS=siti-admin-key-001:ADMIN,siti-ops-key-002:OPERATOR,siti-erp-key-003:INTEGRATOR

# ── WhatsApp Alerts via Twilio (optional) ──────────────────────
# Leave blank — system works fully without WhatsApp.
# Free sandbox: twilio.com → Console → Messaging → WhatsApp Sandbox
# TWILIO_TO supports multiple numbers: whatsapp:+91XXXX,whatsapp:+91YYYY
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=
ALERT_COOLDOWN_MIN=30

# ── CORS ───────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
